flowchart TB
  subgraph entry["Entry"]
    CLI["habit.cli:cli\n(Click group)"]
    API["habit package\nlazy exports"]
  end

  subgraph asm["Configurators"]
    BC["BaseConfigurator"]
    HC["HabitatConfigurator"]
    MC["MLConfigurator"]
    PC["PreprocessingConfigurator"]
    BC --> HC
    BC --> MC
    BC --> PC
  end

  subgraph dom["Domains (no mutual imports)"]
    PRE["preprocessing"]
    HAB["habitat_analysis"]
    ML["machine_learning"]
  end

  subgraph util["Infrastructure"]
    U["habit/utils"]
  end

  CLI --> HC
  CLI --> MC
  CLI --> PC
  API -. optional .-> HAB
  HC --> HAB
  MC --> ML
  PC --> PRE
  PRE --> U
  HAB --> U
  ML --> U

  PRE <-. "artefacts: images, dirs" .-> HAB
  HAB <-. "CSV, NRRD, habitat_pipeline.pkl" .-> ML
